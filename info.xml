<?xml version="1.0"?>
<extension key="com.skvare.datalayer" type="module">
  <file>datalayer</file>
  <name>CiviCRM DataLayer</name>
  <description>Pushes GA4-compatible dataLayer events at every step of CiviCRM Contribution Pages and Event Registration forms. Includes global master controls, entity-type toggles, per-contribution-page and per-event overrides, and feature-level granularity.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Sunil Pawar</author>
    <email>sunil@skvare.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/Skvare/com.skvare.datalayer</url>
    <url desc="Documentation">https://github.com/Skvare/com.skvare.datalayer</url>
    <url desc="Support">https://github.com/Skvare/com.skvare.datalayer</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-05-22</releaseDate>
  <version>1.0.0</version>
  <develStage>alpha</develStage>
  <compatibility>
    <ver>6.4</ver>
  </compatibility>
  <tags>
    <tag>analytics</tag>
    <tag>google-analytics</tag>
    <tag>ga4</tag>
    <tag>gtm</tag>
    <tag>datalayer</tag>
  </tags>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/DataLayer</namespace>
    <format>23.02.1</format>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty-v2@1.0.1</mixin>
    <mixin>menu-xml@1.0.0</mixin>
  </mixins>
</extension>
